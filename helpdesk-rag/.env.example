# Kopyala: cp .env.example .env  (ve .env'i git'e KOYMA)
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=changeme
POSTGRES_DB=helpdesk

# Model ayarları (host'taki Ollama'da çekili olmalı)
LLM_MODEL=qwen3.5:9b
EMBED_MODEL=bge-m3
EMBED_DIM=1024          # bge-m3 -> 1024 boyut. Model değişirse init.sql'i de güncelle.

# RAG parametreleri
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
