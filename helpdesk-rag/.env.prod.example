# Prod ortam değişkenleri. Kopyala: cp .env.prod.example .env.prod
# .env.prod ASLA git'e girmemeli (.gitignore'da).

# --- Erişim ---
PUBLIC_HOST=helpdesk.sirket.local
PUBLIC_URL=https://helpdesk.sirket.local

# --- Veritabanı ---
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=            # GÜÇLÜ bir şifre üretin: openssl rand -base64 32
POSTGRES_DB=helpdesk

# --- Microsoft Entra ID (M365) SSO ---
# IT'den uygulama kaydı (app registration) talep edin.
# Redirect URI: https://helpdesk.sirket.local/oauth/oidc/callback
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# --- Modeller (host'taki Ollama'da çekili olmalı) ---
# Kullanıcıya giden cevaplar: kalite öncelikli
LLM_MODEL=qwen3.5:27b
# Triyaj/sınıflandırma: hız öncelikli, yüksek hacim
TRIAGE_MODEL=qwen3.5:9b
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# --- RAG ayarları ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
